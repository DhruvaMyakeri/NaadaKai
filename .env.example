# Copy to .env (or .env.local) and fill in your keys. Never commit .env itself.

# ── Core (required to actually make anything work) ──
GROQ_API_KEY=your_groq_key_here
REACTOR_API_KEY=your_reactor_key_here
NVIDIA_NEMO_KEY=your_nvidia_nemo_key_here

# ── Auth / login (Vercel-only in prod) ──
# Show the "sign in with Google" button on the frontend. If you just want
# to SEE the button without setting up Google OAuth, leave the two
# GOOGLE vars blank — the button renders but clicking it will fail.
# NEXT_PUBLIC_AUTH_ENABLED=true
# AUTH_SECRET=generate_with_openssl_rand_base64_32
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...

# ── Play-gate (needs Postgres) ──
# When DATABASE_URL is unset, plays are unlimited (gate is invisible).
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
# PLAY_LIMIT_ANON=1
# PLAY_LIMIT_USER=5
# IP_HASH_SALT=change_me_to_a_long_random_string

# ── Vercel ↔ Vultr backend split (prod only) ──
# When BACKEND_BASE_URL is unset, /api/compose and /api/extract run
# in-process on this box. When set, the frontend forwards them to Vultr.
# BACKEND_BASE_URL=http://your-vultr-ip:3000
# BACKEND_SHARED_SECRET=change_me_to_a_long_random_string

# ── Upload / extractor UI ──
# The extractor is disabled in prod (no GPU on Vercel/Vultr). Setting
# this to "true" locally re-enables the upload dropzone.
# NEXT_PUBLIC_ENABLE_UPLOAD=true
